# Olmec Configuration

# Deployment mode: "local", "pi", "cloud"
OLMEC_MODE=local

# Cloud demo mode password (required for cloud mode)
OLMEC_PASSWORD=changeme

# Active voice directory name (under data/audio/)
OLMEC_VOICE=olmec-v1

# Audio device selection (Pi mode) — substring of device name to match
# Run `curl http://localhost:8000/api/audio/devices` to see what's available
OLMEC_AUDIO_INPUT_DEVICE=
OLMEC_AUDIO_OUTPUT_DEVICE=

# ElevenLabs API key (for audio generation pipeline)
ELEVENLABS_API_KEY=

# ElevenLabs voice ID
ELEVENLABS_VOICE_ID=

# Anthropic API key (for question extraction pipeline + cloud LLM mode)
ANTHROPIC_API_KEY=

# Server
OLMEC_HOST=0.0.0.0
OLMEC_PORT=8000
